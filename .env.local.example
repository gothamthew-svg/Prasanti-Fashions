# ================================================================
# Pra Fashions — Environment Variables — prafashions.com
#
# Copy to .env.local for local dev.
# Add ALL to Vercel → Project Settings → Environment Variables for prod.
# NEVER commit .env.local to git.
# ================================================================

# ── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://prafashions.com

# ── Stripe ───────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
# Use pk_test_ / sk_test_ locally, pk_live_ / sk_live_ in prod
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Stripe Dashboard → Developers → Webhooks → Signing secret
# Endpoint URL: https://prafashions.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────────
# https://resend.com — 3,000 emails/month free
# Verify prafashions.com domain in Resend, then update "from" addresses in API routes
RESEND_API_KEY=re_...
CONTACT_EMAIL=hello@prafashions.com

# ── Google Sheets (Product CMS) ───────────────────────────────────
# Sheet ID from URL: docs.google.com/spreadsheets/d/THIS_ID/edit
GOOGLE_SHEET_ID=your_sheet_id_here
# https://console.cloud.google.com — Google Sheets API key (restrict to prafashions.com)
GOOGLE_SHEETS_API_KEY=AIza...

# ── Sentry (Error Monitoring) ─────────────────────────────────────
# https://sentry.io — 5,000 errors/month free
NEXT_PUBLIC_SENTRY_DSN=https://...@o...ingest.sentry.io/...
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=prafashions
SENTRY_AUTH_TOKEN=sntrys_...

# ── Google Analytics 4 ────────────────────────────────────────────
# https://analytics.google.com — Measurement ID looks like G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Mom's Update Button ───────────────────────────────────────────
# Vercel → Project → Settings → Git → Deploy Hooks → Create Hook
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
# Her update URL: https://prafashions.com/api/redeploy?key=YOUR_SECRET_HERE
REDEPLOY_SECRET=your-secret-word-here

# ── Namecheap DNS Setup (reference — not used in code) ───────────
# 1. Namecheap → Domain List → Manage → Advanced DNS
# 2. Delete existing records, then add:
#    Type=A,     Host=@,   Value=76.76.21.21,         TTL=Auto
#    Type=CNAME, Host=www, Value=cname.vercel-dns.com, TTL=Auto
# 3. Vercel → Project → Settings → Domains → add prafashions.com + www.prafashions.com
# 4. Vercel handles SSL automatically via Let's Encrypt

# ── NextAuth (Google Login) ───────────────────────────────────────────────
# 1. Go to console.cloud.google.com → your project
# 2. APIs & Services → Credentials → Create → OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs: https://prafashions.com/api/auth/callback/google
#    (also add http://localhost:3000/api/auth/callback/google for local dev)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Random secret for encrypting JWT sessions — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=https://prafashions.com
# Local dev: NEXTAUTH_URL=http://localhost:3000

# Comma-separated Gmail addresses that can access /admin
# Add everyone who needs admin access here
ADMIN_EMAILS=you@gmail.com,mom@gmail.com

# ── Supabase (Database) ───────────────────────────────────────────────────
# 1. Go to supabase.com → New Project → name it "prafashions"
# 2. Wait for it to start (~2 min)
# 3. Project Settings → API → copy the values below
# 4. Run supabase-schema.sql in Supabase → SQL Editor → New Query → Run
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NEVER expose this publicly

# ── Cloudinary (Image Storage) ────────────────────────────────────────────
# 1. Go to cloudinary.com → free account
# 2. Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret
